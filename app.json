{
  "expo": {
    "name": "Swayam Shiksha",
    "slug": "swayam-shiksha",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "swayam-shiksha",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0e1a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.swayamshiksha.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0f0e1a"
      },
      "package": "com.swayamshiksha.app"
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "2db463f5-3ea6-46c1-9df4-f1c4c6922c28"
      }
    }
  }
}